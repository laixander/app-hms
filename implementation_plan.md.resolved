в”‚   в””в”Ђв”Ђ kiosk/
в”‚       в””в”Ђв”Ђ KioskTicketModal.vue
в”њв”Ђв”Ђ composables/
в”‚   в”њв”Ђв”Ђ useLanguage.ts
в”‚   в””в”Ђв”Ђ useQueueState.ts
в”њв”Ђв”Ђ layouts/
